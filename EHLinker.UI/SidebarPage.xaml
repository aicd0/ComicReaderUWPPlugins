<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EHLinker.UI.SidebarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EHLinker.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <SelectorBar
            x:Name="TabSelectorBar"
            Grid.Row="0"
            Margin="14,0"
            Padding="0,12,0,8"
            SelectionChanged="TabSelectorBar_SelectionChanged">
            <SelectorBarItem
                x:Name="TabSelectorBarItemLinker"
                Padding="12,0,12,4"
                Text="Linker" />
            <SelectorBarItem
                x:Name="TabSelectorBarItemComments"
                Padding="12,0,12,4"
                Text="Comments" />
        </SelectorBar>

        <Rectangle
            Grid.Row="1"
            Height="1"
            Fill="#404040" />

        <Grid Grid.Row="2">
            <Grid x:Name="LinkerTabGrid">
                <TextBlock x:Name="TestTextBlock" Text="This is linker" />
            </Grid>
            <Grid x:Name="CommentsTabGrid">
                <TextBlock Text="This is comments" />
            </Grid>
        </Grid>
    </Grid>

</Page>
