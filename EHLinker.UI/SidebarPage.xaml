<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="EHLinker.UI.SidebarPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:EHLinker.UI"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Loaded="Page_Loaded"
    Unloaded="Page_Unloaded"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <SelectorBar
            x:Name="TabSelectorBar"
            Grid.Row="0"
            Margin="14,0"
            Padding="0,12,0,8"
            SelectionChanged="TabSelectorBar_SelectionChanged">
            <SelectorBarItem
                x:Name="TabSelectorBarItemLinker"
                Padding="12,0,12,4"
                Text="Linker" />
            <SelectorBarItem
                x:Name="TabSelectorBarItemInfo"
                Padding="12,0,12,4"
                Text="Info" />
        </SelectorBar>

        <Grid Grid.Row="1">
            <Grid x:Name="LinkerTabGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <StackPanel
                    Grid.Row="0"
                    Margin="8,0"
                    Orientation="Vertical">
                    <TextBlock
                        Margin="7,10,7,0"
                        FontWeight="SemiLight"
                        IsTextSelectionEnabled="True"
                        Text="{x:Bind ViewModel.LinkStatusText, Mode=OneWay}"
                        TextWrapping="Wrap" />
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Text="{x:Bind ViewModel.ComicSearchBoxText, Mode=TwoWay}" />
                        <Button
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            Click="SearchComicButton_Click"
                            Content="Search" />
                    </Grid>
                    <CheckBox
                        Margin="0,6,0,0"
                        Click="DisableSearchFilterCheckBox_Click"
                        Content="Disable filters"
                        IsChecked="{x:Bind ViewModel.DisableSearchFilterChecked, Mode=TwoWay}" />
                    <Button
                        Margin="0,6,0,0"
                        HorizontalAlignment="Stretch"
                        Click="EditCookiesButton_Click"
                        Content="Edit cookies..." />
                    <Grid Margin="0,6,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button
                            Grid.Column="0"
                            HorizontalAlignment="Stretch"
                            Click="SearchComicPreviousPageButton_Click"
                            Content="Previous"
                            IsEnabled="{x:Bind ViewModel.SearchComicPreviousPageEnabled, Mode=OneWay}" />
                        <Button
                            Grid.Column="1"
                            Margin="4,0,0,0"
                            HorizontalAlignment="Stretch"
                            Click="SearchComicNextPageButton_Click"
                            Content="Next"
                            IsEnabled="{x:Bind ViewModel.SearchComicNextPageEnabled, Mode=OneWay}" />
                    </Grid>
                </StackPanel>
                <TextBlock
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    HorizontalAlignment="Center"
                    FontWeight="Bold"
                    Text="No hits found"
                    TextWrapping="Wrap"
                    Visibility="{x:Bind ViewModel.SearchResultEmptyVisible, Mode=OneWay}" />
                <ListView
                    Grid.Row="1"
                    Margin="4,6,4,0"
                    ContextRequested="ListView_ContextRequested"
                    ItemsSource="{x:Bind ViewModel.ComicSearchResultItems}"
                    SelectionChanged="SearchComicResultListView_SelectionChanged">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ComicSearchResultItemViewModel">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <TextBlock
                                    Grid.Row="0"
                                    Text="{x:Bind Title}"
                                    TextWrapping="Wrap" />
                                <TextBlock
                                    Grid.Row="1"
                                    Opacity="0.8"
                                    Text="{x:Bind Description}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                    <ListView.ItemContainerStyle>
                        <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="VerticalContentAlignment" Value="Stretch" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Padding" Value="16,8,12,8" />
                        </Style>
                    </ListView.ItemContainerStyle>
                </ListView>
            </Grid>

            <Grid x:Name="InfoTabGrid">
                <Grid Visibility="{x:Bind ViewModel.InfoTabRetryVisible, Mode=OneWay}">
                    <StackPanel
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Orientation="Vertical">
                        <TextBlock
                            Margin="15,0"
                            HorizontalAlignment="Center"
                            FontWeight="SemiLight"
                            Text="{x:Bind ViewModel.RequestInfoErrorMessage, Mode=OneWay}"
                            TextWrapping="Wrap" />
                        <Button
                            Margin="0,10,0,0"
                            HorizontalAlignment="Center"
                            Click="RequestInfoRetryButton_Click"
                            Content="Retry" />
                    </StackPanel>
                </Grid>
                <ScrollViewer
                    Padding="15,0,15,0"
                    VerticalScrollBarVisibility="Auto"
                    Visibility="{x:Bind ViewModel.InfoTabContentVisible, Mode=OneWay}">
                    <StackPanel Orientation="Vertical">
                        <TextBlock
                            Margin="0,10,0,0"
                            FontSize="20"
                            FontWeight="SemiLight"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind ViewModel.ComicTitle1, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Visibility="{x:Bind ViewModel.ComicTitle1Visible, Mode=OneWay}" />
                        <TextBlock
                            Margin="0,10,0,0"
                            FontSize="20"
                            FontWeight="SemiLight"
                            IsTextSelectionEnabled="True"
                            Text="{x:Bind ViewModel.ComicTitle2, Mode=OneWay}"
                            TextWrapping="Wrap"
                            Visibility="{x:Bind ViewModel.ComicTitle2Visible, Mode=OneWay}" />
                        <Rectangle
                            Height="1"
                            Margin="0,18,0,9"
                            Fill="{ThemeResource TextFillColorPrimaryBrush}"
                            Opacity="0.1" />
                        <ListView ItemsSource="{x:Bind ViewModel.ComicCommentItems}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="local:CommentItemViewModel">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="0"
                                            IsTextSelectionEnabled="True"
                                            Opacity="0.8"
                                            Text="{x:Bind Sender}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Row="0"
                                            Grid.Column="1"
                                            Opacity="0.8"
                                            Text="{x:Bind Detail}"
                                            TextTrimming="CharacterEllipsis" />
                                        <TextBlock
                                            Grid.Row="1"
                                            Grid.ColumnSpan="2"
                                            IsTextSelectionEnabled="True"
                                            Text="{x:Bind Content}"
                                            TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                            <ListView.ItemContainerStyle>
                                <Style BasedOn="{StaticResource DefaultListViewItemStyle}" TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="VerticalContentAlignment" Value="Stretch" />
                                    <Setter Property="Margin" Value="0" />
                                    <Setter Property="Padding" Value="0,9" />
                                </Style>
                            </ListView.ItemContainerStyle>
                        </ListView>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>

</Page>
